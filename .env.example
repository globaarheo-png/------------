TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here

# GigaChat API
# Use Authorization Key from GigaChat, not an OAuth access token.
GIGACHAT_AUTH_KEY=put_base64_authorization_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=put_supabase_service_or_anon_key_here
